# Copy to .env and fill in for local development
# Never commit .env to git

ENV=development

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=job-search-agent-bucket
KMS_KEY_NAME=projects/your-project/locations/global/keyRings/job-search/cryptoKeys/api-keys

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Local dev only — in prod these come from Cloud Run env vars
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
